POSTGRES_DB=labkit
POSTGRES_USER=labkit
POSTGRES_PASSWORD=labkit
# Use :80 for local HTTP-only dev. Set this to your real domain in production,
# for example: lab.ics.astralis.icu
LABKIT_SITE_ADDRESS=:80
LABKIT_HTTP_PORT=8080
LABKIT_HTTPS_PORT=8443
LABKIT_ADMIN_TOKEN=dev-admin-token
LABKIT_ARTIFACT_ROOT=/var/lib/labkit/artifacts
# Set true for local-only auth shortcut flows and the dev device bind endpoint.
LABKIT_DEV_MODE=false
LABKIT_OAUTH_CLIENT_ID=dev-client-id
LABKIT_OAUTH_CLIENT_SECRET=dev-client-secret
LABKIT_OAUTH_REDIRECT_URL=http://localhost:8080/api/device/verify
LABKIT_OAUTH_AUTHORIZE_URL=https://example.invalid/oauth/authorize
LABKIT_OAUTH_TOKEN_URL=https://example.invalid/oauth/token
LABKIT_OAUTH_PROFILE_URL=https://example.invalid/oauth/profile
LABKIT_OAUTH_DEVICE_AUTH_TTL=15m
LABKIT_WORKER_ID=compose-worker
LABKIT_WORKER_POLL_INTERVAL_MS=1000
LABKIT_WORKER_WORKSPACE_ROOT=/tmp/labkit-worker
LABKIT_WORKER_MEMORY_LIMIT=512m
LABKIT_WORKER_CPU_LIMIT=2
