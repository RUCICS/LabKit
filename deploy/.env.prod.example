POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=labkit
POSTGRES_USER=labkit
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_SSLMODE=disable

LABKIT_SITE_ADDRESS=lab.ics.astralis.icu
LABKIT_HTTP_PORT=80
LABKIT_HTTPS_PORT=443

LABKIT_ADMIN_TOKEN=replace-with-strong-random-token
LABKIT_ARTIFACT_ROOT=/var/lib/labkit/artifacts
LABKIT_QUOTA_TIMEZONE=Asia/Shanghai
LABKIT_DEV_MODE=false
# Provider-based auth config. Current templates default to cas_ruc.
LABKIT_AUTH_PROVIDER=cas_ruc

LABKIT_OAUTH_CLIENT_ID=replace-with-school-client-id
LABKIT_OAUTH_CLIENT_SECRET=replace-with-school-client-secret
LABKIT_OAUTH_REDIRECT_URL=https://lab.ics.astralis.icu/api/device/verify
LABKIT_OAUTH_AUTHORIZE_URL=https://cas.ruc.edu.cn/cas/oauth2.0/authorize
LABKIT_OAUTH_TOKEN_URL=https://cas.ruc.edu.cn/cas/oauth2.0/accessToken
LABKIT_OAUTH_PROFILE_URL=https://cas.ruc.edu.cn/cas/oauth2.0/user/profiles
LABKIT_OAUTH_DEVICE_AUTH_TTL=15m

LABKIT_WORKER_ID=prod-worker-1
LABKIT_WORKER_POLL_INTERVAL_MS=1000
LABKIT_WORKER_WORKSPACE_ROOT=/tmp/labkit-worker
LABKIT_WORKER_MEMORY_LIMIT=1g
LABKIT_WORKER_CPU_LIMIT=2
